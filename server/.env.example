# Environment variables for the Flask backend.
FLASK_PORT=5000
FLASK_DEBUG=0

# ─── Database ────────────────────────────────────────────────────────────────
# DB keep-alive applies to the configured auth DB backend.
DB_KEEPALIVE_ENABLED=1
DB_KEEPALIVE_INTERVAL_MINUTES=5  # minutes between keep-alive pings to prevent DB from locking during long scrapes

# Auth DB backend
# Supported: oracle, sqlite
AUTH_DB_ENGINE=oracle

# SQLite path used only when AUTH_DB_ENGINE=sqlite
AUTH_SQLITE_DB_PATH=/path/to/auth.sqlite3

# Course DB backend
# Supported: sqlite
COURSE_DB_ENGINE=sqlite

# Default SQLite file for course/topic content.
COURSE_SQLITE_DB_PATH=/path/to/educative_scraper.db

# Backward-compatible fallback for older configs (used when COURSE_SQLITE_DB_PATH is not set)
DB_PATH=/path/to/educative_scraper.db

# Optional course DB sharding by course ID range.
# Leave blank for single DB mode.
# Example JSON:
# [{"start_id":1,"end_id":999,"db_path":"/path/to/course_shard_a.db"},
#  {"start_id":1000,"end_id":1999,"db_path":"/path/to/course_shard_b.db"}]
COURSE_SQLITE_SHARDS_JSON=


# ─── Oracle ADW — Auth (users) database ──────────────────────────────────────
# The auth (users) DB is stored in Oracle Autonomous Database.
# Match values from your Oracle Wallet / ADW connection profile.
# Used when AUTH_DB_ENGINE=oracle.

ORACLE_USER=EDU
ORACLE_PASSWORD=your_db_password

# TNS service name from tnsnames.ora (e.g. personal_low, personal_medium, personal_high)
ORACLE_DSN=personal_high

# Path to the directory containing tnsnames.ora, sqlnet.ora, and the wallet files
ORACLE_WALLET_DIR=/path/to/Wallet_personal

# Leave blank if the wallet requires no separate password
ORACLE_WALLET_PASSWORD=

# Connection pool sizing
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=5

# Set to "1" only when using Oracle Instant Client (thick mode).
# Leave "0" for thin mode — no local Oracle client required (recommended).
ORACLE_THICK_MODE=0

# Required only when ORACLE_THICK_MODE=1 and client libs are not already on PATH
ORACLE_LIB_DIR=


# ─── Auth / JWT ───────────────────────────────────────────────────────────────
# Same secret as NEXT_PUBLIC_... NEVER share — must match Next.js JWT_SECRET
JWT_SECRET=changeme-dev-secret
JWT_EXPIRES_DAYS=7
# Comma-separated allowed invite codes (leave empty to accept any non-empty code)
INVITE_CODES=abcdef
# Issuer label shown in authenticator apps
TOTP_ISSUER=EduViewer

# ── RSA key pair for password encryption ──────────────────────────────────────
# If blank, a new key is generated on every restart (insecure — public key changes).
# On first run, the server logs the generated key. Copy it here (one-liner, \n separators).
# The matching public key will be printed to the log — paste it into client/.env.local.
RSA_PRIVATE_KEY=

