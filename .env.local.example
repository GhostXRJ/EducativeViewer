# ── Proxy / middleware ────────────────────────────────────────────────────────
# Secret injected by the Cloudflare Worker into every request (x-edu-proxy header).
# Must match the PROXY_SECRET in your Cloudflare Worker.
PROXY_SECRET=your-proxy-secret-here

# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL of the Cloudflare Worker that proxies Flask API calls.
BACKEND_API_BASE=https://your-api-worker.workers.dev/

# ── Static files CDN ──────────────────────────────────────────────────────────
# Base URL of the Cloudflare Worker / R2 bucket serving static assets.
NEXT_PUBLIC_STATIC_FILES_BASE=https://your-static-worker.workers.dev/

# ── Environment ───────────────────────────────────────────────────────────────
# Set to "development" locally. On Vercel this is set automatically.
# Used to skip middleware auth checks and disable ISR caching in dev.
VERCEL_ENV=development

# ── Cache revalidation webhook ────────────────────────────────────────────────
# Shared secret between this Next.js app and the Flask backend.
# Must match REVALIDATE_SECRET in server/.env
REVALIDATE_SECRET=your-revalidate-secret-here
